# =============================================================================
# .gitignore — Android · Swift/iOS · Node.js · JavaScript · React · macOS · Windows
# =============================================================================


# =============================================================================
# OPERATING SYSTEMS
# =============================================================================

# ── macOS ────────────────────────────────────────────────────────────────────
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
.AppleDouble
.LSOverride
.DocumentRevisions-V100
.fseventsd
.TemporaryItems
.VolumeIcon.icns
.com.apple.timemachine.donotpresent
.AppleDB
.AppleDesktop
Network Trash Folder
Temporary Items
Icon?

# ── Windows ──────────────────────────────────────────────────────────────────
Thumbs.db
Thumbs.db:encryptable
ehthumbs.db
ehthumbs_vista.db
Desktop.ini
$RECYCLE.BIN/
*.cab
*.msi
*.msix
*.msm
*.msp
*.lnk
[Dd]esktop.ini


# =============================================================================
# EDITORS & IDEs
# =============================================================================

# ── VS Code ───────────────────────────────────────────────────────────────────
.vscode/*
!.vscode/settings.json
!.vscode/tasks.json
!.vscode/launch.json
!.vscode/extensions.json
!.vscode/*.code-snippets
.history/
*.vsix

# ── JetBrains (Android Studio / IntelliJ / AppCode) ──────────────────────────
.idea/
*.iml
*.iws
*.ipr
out/
.idea_modules/
atlassian-ide-plugin.xml
com_crashlytics_export_strings.xml
crashlytics.properties
crashlytics-build.properties
fabric.properties

# ── Xcode ────────────────────────────────────────────────────────────────────
xcuserdata/
*.xcscmblueprint
*.xccheckout
*.moved-aside
DerivedData/
*.hmap
*.ipa
*.dSYM.zip
*.dSYM

# ── Vim / Emacs / Sublime ─────────────────────────────────────────────────────
*.swp
*.swo
*~
*.orig
.project
.classpath


# =============================================================================
# ANDROID
# =============================================================================

# Build outputs
*.apk
*.aab
*.ap_
*.dex
bin/
gen/
out/
build/
local.properties

# Gradle
.gradle/
gradle-app.setting
!gradle-wrapper.jar
.gradletasknamecache

# ProGuard
proguard/
*.pro

# Keystore — NEVER commit signing keys
*.jks
*.keystore
release.properties
signing.properties

# NDK / CMake
*.so
obj/
.cxx/
cmake-build-*/

# Navigation component
.navigation/

# Lint
lint/intermediates/
lint/generated/
lint/outputs/
lint/tmp/


# =============================================================================
# SWIFT / iOS / macOS (Xcode)
# =============================================================================

# Build
build/
DerivedData/
*.pbxuser
!default.pbxuser
*.mode1v3
!default.mode1v3
*.mode2v3
!default.mode2v3
*.perspectivev3
!default.perspectivev3

# Pods (CocoaPods) — uncomment if not committing Pods
# Pods/
# Podfile.lock

# Swift Package Manager
.build/
.swiftpm/
*.resolved

# Carthage
Carthage/Build/

# Fastlane
fastlane/report.xml
fastlane/Preview.html
fastlane/screenshots/**/*.png
fastlane/test_output/

# Simulators & archives
*.xcarchive
*.app
*.ipa

# Instruments
timeline.xctimeline
playground.xcworkspace


# =============================================================================
# NODE.JS
# =============================================================================

# Dependencies
node_modules/
jspm_packages/
bower_components/

# Logs
logs/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
lerna-debug.log*
.pnpm-debug.log*

# Runtime & caches
.npm/
.yarn/cache/
.yarn/unplugged/
.yarn/build-state.yml
.yarn/install-state.gz
.pnp.*
.node_repl_history
pids/
*.pid
*.seed
*.pid.lock
lib-cov/
coverage/
*.lcov
.nyc_output/

# Build outputs
dist/
dist-ssr/
build/

# Optional caches
.eslintcache
.stylelintcache
.parcel-cache/
.cache/
.turbo/

# env files — keep examples, ignore secrets
.env
.env.*
!.env.example
!.env.sample
!.env.template

# setup-macos: config local con secretos (ignorar), pero versionar la plantilla
setup.env
!setup.env.example

# Lock files — choose ONE convention per project; keep only what you use
# Uncomment the ones you DON'T use to avoid committing them:
# package-lock.json
# yarn.lock
# pnpm-lock.yaml

# Serverless
.serverless/
.dynamodb/

# Miscellaneous
.node_modules.bak/


# =============================================================================
# JAVASCRIPT / TYPESCRIPT
# =============================================================================

# Compiled output
*.js.map
*.d.ts
*.d.ts.map
*.tsbuildinfo
tsconfig.tsbuildinfo

# Type checking cache
.tscache/

# Storybook
storybook-static/
.storybook/node_modules/

# Microbundle / Rollup cache
.rpt2_cache/
.rts2_cache_cjs/
.rts2_cache_es/
.rts2_cache_umd/


# =============================================================================
# REACT (CRA / Vite / Next.js)
# =============================================================================

# CRA / Vite build
build/
dist/
.vite/

# Next.js
.next/
out/
.vercel/
.next/cache/
next-env.d.ts

# Expo (React Native)
.expo/
.expo-shared/
web-build/
*.jsbundle

# Testing
coverage/
jest.config.js.cache


# =============================================================================
# TESTING & QUALITY
# =============================================================================

coverage/
.nyc_output/
test-results/
*.snap         # Jest snapshots — commit intentionally, ignore if auto-generated
playwright-report/
.playwright/


# =============================================================================
# SECRETS & CREDENTIALS  ⚠️  CRITICAL
# =============================================================================

*.pem
*.key
*.p12
*.p8
*.cert
*.cer
.secret
secrets/
credentials/
service-account*.json
google-services.json        # Android Firebase — add to VCS only if no secrets
GoogleService-Info.plist    # iOS Firebase — same caveat


# =============================================================================
# MISC
# =============================================================================

# Archives
*.zip
*.tar.gz
*.rar
*.7z

# Temporary files
tmp/
temp/
*.tmp
*.bak
*.swp

# Package managers
.pnpm-store/
.yarn-integrity
