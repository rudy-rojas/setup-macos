# =============================================================================
# setup.env.example — plantilla de configuración local de setup-macos
#
# CÓMO USAR:
#   1. Copia esta plantilla:   cp setup.env.example setup.env
#   2. Rellena los valores que necesites (todos son OPCIONALES).
#   3. Corre normalmente:       ./setup.sh
#
# setup.sh lee 'setup.env' al inicio (si existe) y exporta estas variables, de
# modo que los módulos las heredan SIN prompts a media instalación.
#
# 'setup.env' está en .gitignore: NO se sube al repo (puede contener secretos).
# Esta plantilla (setup.env.example) SÍ se versiona, pero sin valores reales.
# Si no creas 'setup.env', el setup corre igual con los valores por defecto.
# =============================================================================

# ── 05. Git ──────────────────────────────────────────────────────────────────
# Identidad para 'git config --global'. Por defecto, la del equipo TNB.
# GIT_USER_NAME="Tu Nombre"
# GIT_USER_EMAIL="tu@correo.com"

# ── 08. PostgreSQL ───────────────────────────────────────────────────────────
# Bases vacías a crear (separadas por espacios), con extensiones citext/pgcrypto/
# pg_trgm. Si lo dejas vacío, NO se crea ninguna base (restauras desde backup).
# Postgres NO usa contraseña (auth 'trust' por socket local), así que no hay
# ninguna credencial que poner aquí.
# PG_DATABASES="tnb_dev nexus_erp testscript"

# ── 10. MySQL ────────────────────────────────────────────────────────────────
# Contraseña de root de MySQL. Se aplica de forma NO interactiva (sin prompt).
# Si lo dejas vacío, MySQL queda SIN contraseña de root (default de brew) y solo
# verás un aviso. Pon aquí la que espera tu .env (v1 / tnb-backend).
# MYSQL_ROOT_PASSWORD=""

# ── 12. iOS (opt-in) ─────────────────────────────────────────────────────────
# 0 = omitir el módulo iOS (por defecto).  1 = ejecutarlo (~12 GB de Xcode).
# Ponlo en 1 SOLO si vas a hacer builds locales de iOS (expo run:ios / prebuild)
# y ya tienes (o instalarás) Xcode desde la Mac App Store. Con EAS Build (nube)
# normalmente NO hace falta: déjalo en 0.
INSTALL_IOS=0
