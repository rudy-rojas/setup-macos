# =============================================================================
# setup.env.example — local configuration template for setup-macos
#
# HOW TO USE:
#   1. Copy this template:      cp setup.env.example setup.env
#   2. Fill in the values you need (all are OPTIONAL).
#   3. Run as usual:            ./setup.sh
#
# setup.sh reads 'setup.env' at startup (if it exists) and exports these
# variables, so the modules inherit them WITHOUT prompts mid-install.
#
# 'setup.env' is in .gitignore: it is NOT pushed to the repo (it may contain secrets).
# This template (setup.env.example) IS versioned, but without real values.
# If you do not create 'setup.env', the setup still runs with the default values.
# =============================================================================

# ── 05. Git ──────────────────────────────────────────────────────────────────
# Identity for 'git config --global'. Defaults to the TNB team's.
# GIT_USER_NAME="Your Name"
# GIT_USER_EMAIL="you@email.com"

# ── 08. PostgreSQL ───────────────────────────────────────────────────────────
# Empty databases to create (space-separated), with the citext/pgcrypto/
# pg_trgm extensions. If left empty, NO database is created (you restore from backup).
# Postgres uses no password ('trust' auth over the local socket), so there is
# no credential to set here.
# PG_DATABASES="tnb_dev nexus_erp testscript"

# ── 10. MySQL ────────────────────────────────────────────────────────────────
# MySQL root password. Applied non-interactively (no prompt).
# If left empty, MySQL is left with NO root password (brew default) and you will
# only see a warning. Set here the one your .env expects (v1 / tnb-backend).
# MYSQL_ROOT_PASSWORD=""

# ── 11. Android (Android Studio optional) ────────────────────────────────────
# Module 11 ALWAYS installs the headless toolchain (watchman, JDK 17, Android
# SDK via cmdline-tools, EAS CLI). Android Studio (the GUI, ~1.2 GB) is OPTIONAL:
# it is not needed for RN/Expo with EAS; useful for the AVD Manager, the emulator
# and debugging. 0 = skip (default). 1 = install the android-studio cask.
INSTALL_ANDROID_STUDIO=0

# ── 12. iOS (opt-in) ─────────────────────────────────────────────────────────
# 0 = skip the iOS module (default).  1 = run it (~12 GB of Xcode).
# Set it to 1 ONLY if you are going to do local iOS builds (expo run:ios / prebuild)
# and you already have (or will install) Xcode from the Mac App Store. With EAS Build
# (cloud) it is usually NOT needed: leave it at 0.
INSTALL_IOS=0
